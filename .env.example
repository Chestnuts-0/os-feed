# ════════════════════════════════════════════════════════════════
# 开源版抖音信息流 — 环境变量示例
# 复制为 .env（本地开发）或配置 GitHub Secrets（线上 Actions）
# ════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────
# 默认用 Agnes（免费、OpenAI 兼容）
# 可选: agnes | anthropic | openai | deepseek | openrouter | github-copilot
LLM_PROVIDER=agnes

# ── Agnes AI (https://platform.agnes-ai.com 获取 key) ────────────
AGNES_API_KEY=your_agnes_api_key_here
AGNES_MODEL=Agnes-2.0-Flash

# ── 备选 provider（按 LLM_PROVIDER 切换时启用）──────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=

# ── GitHub ───────────────────────────────────────────────────────
# GitHub Actions 运行时会自动注入 GITHUB_TOKEN；本地运行需自备 PAT
GITHUB_TOKEN=your_github_personal_access_token

# 写入 Issue 的目标仓库（格式: 用户名/仓库名）
DIGEST_REPO=your-username/os-feed

# ── 推送渠道（可选，按需开启）──────────────────────────────────
# 飞书自定义机器人 webhook（多个用逗号分隔）
FEISHU_WEBHOOK_URLS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Product Hunt（可选数据源）
PRODUCTHUNT_TOKEN=

# ── 关注大牛清单（逗号分隔的 GitHub 用户名）──────────────────────
# 留空则用 config.yml 里的默认；也可在 config.yml 配置
BIGBROS=
